# ===========================================
# SIEGE Server — Environment Variables
# ===========================================
# Copy this file to `.env` and fill in the values.
# NEVER commit your .env file to version control.
# ===========================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/siege

# --- Authentication ---
JWT_SECRET=your-jwt-secret-key-change-this
JWT_EXPIRES_IN=7d

# --- HMAC (Telemetry Payload Signing) ---
HMAC_SECRET=your-hmac-base-secret-change-this

# --- CORS ---
CORS_ORIGIN=http://localhost:3000
