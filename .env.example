# ===========================================
# SIEGE — Environment Variables Template
# ===========================================
# Copy this file to `.env` and fill in the values.
# NEVER commit your .env file to version control.
# ===========================================

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/siege
# POSTGRES_URL=postgresql://user:password@localhost:5432/siege

# --- Authentication ---
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Client ---
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# --- HMAC Signing (Telemetry Security) ---
HMAC_SECRET=your-hmac-secret-here

# --- Optional: External Services ---
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
